# Copy to .env and fill in values. Never commit .env to git.
# Recipients are server-only — they never appear in the browser bundle.

FEATURE_REQUEST_RECIPIENTS=you@cornell.edu,other@gmail.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=MEM Planner <your-sender@gmail.com>

PORT=3001
