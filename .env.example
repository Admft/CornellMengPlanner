# Copy to .env and fill in values. Never commit .env to git.
# Recipients are server-only — they never appear in the browser bundle.
#
# Quick setup:  npm run setup:email
#
# Option A — Gmail SMTP (recommended, supports multiple recipients)
FEATURE_REQUEST_RECIPIENTS=you@cornell.edu,other@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=MEM Planner <your-gmail@gmail.com>
#
# Option B — Resend (good for Vercel; set RESEND_API_KEY instead of SMTP)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=MEM Planner <you@yourdomain.com>

PORT=3001
